{
  "_comment": "V2bX agent config. Valid JSON — the leading underscore keys below are documentation only and are ignored by the parser, so you can copy this file, edit the real fields, and leave the comments in place or delete them.",

  "log": {
    "_comment": "level: debug|info|warn|error. output: \"stdout\" or a file path.",
    "level": "info",
    "output": "stdout"
  },

  "panel": {
    "_comment": "Connection to your V2board-family panel (XBoard, V2Board, or any panel implementing the same UniProxy API). *_path fields are optional overrides — leave them out to use the standard UniProxy routes.",
    "api_host": "https://panel.example.com",
    "api_key": "your-panel-communication-key",
    "sync_interval_seconds": 60,
    "config_path": "/api/v1/server/UniProxy/config",
    "user_path": "/api/v1/server/UniProxy/user",
    "push_path": "/api/v1/server/UniProxy/push",
    "alive_path": "/api/v1/server/UniProxy/alive"
  },

  "nodes": [
    {
      "_comment": "Shadowsocks. cipher/port/users all come from the panel; local fields below are agent-side overrides.",
      "node_id": 1,
      "node_type": "shadowsocks",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "none",
      "tfo": true,
      "sniffing": true,
      "limits": { "default_speed_limit_bytes": 0, "device_limit": 3, "ip_limit": 3, "traffic_reset_day": 1 }
    },
    {
      "_comment": "VMess. Typically fronted by TLS; cert_mode \"http\" issues/renews via HTTP-01, \"dns\" via DNS-01, \"self\" uses cert_file/key_file below.",
      "node_id": 2,
      "node_type": "vmess",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "http",
      "tfo": true,
      "sniffing": true
    },
    {
      "_comment": "VLess with optional XTLS/Vision flow — flow is negotiated per-user via the panel's user list.",
      "node_id": 3,
      "node_type": "vless",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "dns"
    },
    {
      "_comment": "Trojan requires TLS; cert_mode \"self\" needs cert_file/key_file to point at an existing certificate.",
      "node_id": 4,
      "node_type": "trojan",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "self",
      "cert_file": "/etc/v2bx/certs/trojan.crt",
      "key_file": "/etc/v2bx/certs/trojan.key"
    },
    {
      "_comment": "Hysteria v1 — QUIC-based, needs a certificate (self-signed is fine for the client's \"insecure\" mode).",
      "node_id": 5,
      "node_type": "hysteria",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "self",
      "cert_file": "/etc/v2bx/certs/hysteria.crt",
      "key_file": "/etc/v2bx/certs/hysteria.key"
    },
    {
      "_comment": "Hysteria2 — same cert requirements as Hysteria v1.",
      "node_id": 6,
      "node_type": "hysteria2",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "self",
      "cert_file": "/etc/v2bx/certs/hysteria2.crt",
      "key_file": "/etc/v2bx/certs/hysteria2.key"
    },
    {
      "_comment": "TUIC — QUIC-based, also needs a certificate.",
      "node_id": 7,
      "node_type": "tuic",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "self",
      "cert_file": "/etc/v2bx/certs/tuic.crt",
      "key_file": "/etc/v2bx/certs/tuic.key"
    },
    {
      "_comment": "Plain SOCKS5 — no TLS.",
      "node_id": 8,
      "node_type": "socks5",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "none"
    },
    {
      "_comment": "NaiveProxy (HTTP/2 CONNECT-based) — requires TLS to blend in as a normal HTTPS server.",
      "node_id": 9,
      "node_type": "naive",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "http"
    },
    {
      "_comment": "Plain HTTP proxy — no TLS.",
      "node_id": 10,
      "node_type": "http",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "none"
    },
    {
      "_comment": "Mieru.",
      "node_id": 11,
      "node_type": "mieru",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "none"
    },
    {
      "_comment": "AnyTLS — TLS required.",
      "node_id": 12,
      "node_type": "anytls",
      "enabled": true,
      "listen_ip": "0.0.0.0",
      "cert_mode": "self",
      "cert_file": "/etc/v2bx/certs/anytls.crt",
      "key_file": "/etc/v2bx/certs/anytls.key"
    }
  ]
}
